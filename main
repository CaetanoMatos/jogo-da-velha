import tkinter as tk
from tkinter import messagebox
import math

# representação dos jogadores
HUMANO = 'X'
IA = 'O'
VAZIO = ' '

# --- lógica do jogo e ia (minimax + alfa-beta) ---

def verificar_vencedor(tabuleiro, jogador):
    """verifica se o jogador especificado venceu a partida."""
    vitorias = [
        [0, 1, 2], [3, 4, 5], [6, 7, 8], # linhas
        [0, 3, 6], [1, 4, 7], [2, 5, 8], # colunas
        [0, 4, 8], [2, 4, 6]             # diagonais
    ]
    for combinacao in vitorias:
        if tabuleiro[combinacao[0]] == tabuleiro[combinacao[1]] == tabuleiro[combinacao[2]] == jogador:
            return True
    return False

def verificar_empate(tabuleiro):
    """verifica se não há mais espaços vazios no tabuleiro."""
    return VAZIO not in tabuleiro

def avaliar(tabuleiro):
    """função de avaliação para o minimax."""
    if verificar_vencedor(tabuleiro, IA):
        return 10
    elif verificar_vencedor(tabuleiro, HUMANO):
        return -10
    else:
        return 0

def minimax(tabuleiro, profundidade, alpha, beta, maximizando):
    """algoritmo minimax com poda alfa-beta."""
    pontuacao = avaliar(tabuleiro)

    if pontuacao == 10 or pontuacao == -10:
        return pontuacao
    if verificar_empate(tabuleiro):
        return 0

    if maximizando:
        melhor_pontuacao = -math.inf
        for i in range(9):
            if tabuleiro[i] == VAZIO:
                tabuleiro[i] = IA
                pontuacao_atual = minimax(tabuleiro, profundidade + 1, alpha, beta, False)
                tabuleiro[i] = VAZIO
                melhor_pontuacao = max(melhor_pontuacao, pontuacao_atual)
                alpha = max(alpha, melhor_pontuacao)
                if beta <= alpha:
                    break # poda alfa-beta
        return melhor_pontuacao
    else:
        pior_pontuacao = math.inf
        for i in range(9):
            if tabuleiro[i] == VAZIO:
                tabuleiro[i] = HUMANO
                pontuacao_atual = minimax(tabuleiro, profundidade + 1, alpha, beta, True)
                tabuleiro[i] = VAZIO
                pior_pontuacao = min(pior_pontuacao, pontuacao_atual)
                beta = min(beta, pior_pontuacao)
                if beta <= alpha:
                    break # poda alfa-beta
        return pior_pontuacao

def melhor_jogada_ia(tabuleiro):
    """determina a melhor jogada possível para a ia."""
    melhor_pontuacao = -math.inf
    jogada = -1

    for i in range(9):
        if tabuleiro[i] == VAZIO:
            tabuleiro[i] = IA
            pontuacao_atual = minimax(tabuleiro, 0, -math.inf, math.inf, False)
            tabuleiro[i] = VAZIO

            if pontuacao_atual > melhor_pontuacao:
                melhor_pontuacao = pontuacao_atual
                jogada = i

    return jogada


# --- interface gráfica (tkinter) com menu ---

class JogoDaVelhaGUI:
    def __init__(self, root):
        self.root = root
        self.root.title("jogo da velha")
        self.tabuleiro = [VAZIO] * 9
        self.botoes = []
        
        # variáveis de controle de estado
        self.modo_jogo = None # 'ia' ou 'humano'
        self.jogador_atual = HUMANO # para rastrear de quem é a vez no modo humano vs humano
        
        # cria os dois frames (telas) principais
        self.frame_menu = tk.Frame(self.root)
        self.frame_jogo = tk.Frame(self.root)
        
        self.criar_menu()

    def criar_menu(self):
        """cria a tela inicial para seleção do modo de jogo."""
        self.frame_jogo.pack_forget() # oculta o jogo caso esteja visível
        self.frame_menu.pack(padx=40, pady=40) # exibe o menu
        
        # limpa widgets anteriores do menu (se houver)
        for widget in self.frame_menu.winfo_children():
            widget.destroy()

        titulo = tk.Label(self.frame_menu, text="escolha o modo de jogo", font=('Arial', 16, 'bold'))
        titulo.pack(pady=20)

        btn_ia = tk.Button(self.frame_menu, text="1 jogador (vs ia)", font=('Arial', 12), width=20, height=2,
                           command=lambda: self.iniciar_jogo('IA'))
        btn_ia.pack(pady=10)

        btn_humano = tk.Button(self.frame_menu, text="2 jogadores (vs humano)", font=('Arial', 12), width=20, height=2,
                               command=lambda: self.iniciar_jogo('HUMANO'))
        btn_humano.pack(pady=10)

    def iniciar_jogo(self, modo):
        """configura o estado inicial da partida e exibe o tabuleiro."""
        self.modo_jogo = modo
        self.jogador_atual = HUMANO # 'x' sempre começa
        self.tabuleiro = [VAZIO] * 9
        
        self.frame_menu.pack_forget() # oculta o menu
        self.frame_jogo.pack(padx=10, pady=10) # exibe o tabuleiro
        
        self.criar_interface_jogo()

    def criar_interface_jogo(self):
        """cria a grade de 3x3 com botões na janela e botão de voltar."""
        # limpa widgets anteriores do jogo
        for widget in self.frame_jogo.winfo_children():
            widget.destroy()
            
        self.botoes = []
        
        for i in range(9):
            btn = tk.Button(self.frame_jogo, text=VAZIO, font='normal 30 bold', width=5, height=2,
                            bg='white', command=lambda i=i: self.realizar_jogada(i))
            
            # grid
            linha = i // 3
            coluna = i % 3
            btn.grid(row=linha, column=coluna, padx=5, pady=5)
            self.botoes.append(btn)
            
        # botão para voltar ao menu inicial
        btn_voltar = tk.Button(self.frame_jogo, text="voltar ao menu", font=('Arial', 10), 
                               command=self.criar_menu)
        btn_voltar.grid(row=3, column=0, columnspan=3, pady=10, sticky='we')

    def realizar_jogada(self, idx):
        """gerencia o clique nos botões dependendo do modo de jogo selecionado."""
        if self.tabuleiro[idx] != VAZIO:
            return # ignora cliques em espaços já ocupados

        # ---- lógica modo 1 jogador (vs ia) ----
        if self.modo_jogo == 'IA':
            self.tabuleiro[idx] = HUMANO
            self.botoes[idx].config(text=HUMANO, fg='blue')

            # verifica se o humano venceu (ou empatou) antes de passar a vez
            if self.checar_fim_de_jogo(HUMANO):
                return

            self.root.update() # atualiza a tela antes da ia "pensar"
            
            # jogada da ia
            movimento_ia = melhor_jogada_ia(self.tabuleiro)
            if movimento_ia != -1:
                self.tabuleiro[movimento_ia] = IA
                self.botoes[movimento_ia].config(text=IA, fg='red')
                self.checar_fim_de_jogo(IA)

        # ---- lógica modo 2 jogadores (vs humano) ----
        elif self.modo_jogo == 'HUMANO':
            self.tabuleiro[idx] = self.jogador_atual
            cor = 'blue' if self.jogador_atual == HUMANO else 'red'
            self.botoes[idx].config(text=self.jogador_atual, fg=cor)

            if self.checar_fim_de_jogo(self.jogador_atual):
                return

            # alterna a vez de quem joga
            if self.jogador_atual == HUMANO:
                self.jogador_atual = IA # ia aqui representa o 'o' do segundo jogador
            else:
                self.jogador_atual = HUMANO

    def checar_fim_de_jogo(self, jogador):
        """verifica condições de vitória ou empate e exibe um alerta."""
        if verificar_vencedor(self.tabuleiro, jogador):
            if jogador == HUMANO:
                mensagem = "parabéns! o jogador 'x' venceu!"
            else:
                mensagem = "vitória do jogador 'o'! mais sorte na próxima."
            
            messagebox.showinfo("fim de jogo", mensagem)
            self.reiniciar_jogo()
            return True
            
        elif verificar_empate(self.tabuleiro):
            messagebox.showinfo("fim de jogo", "deu velha! empate.")
            self.reiniciar_jogo()
            return True
            
        return False

    def reiniciar_jogo(self):
        """limpa o tabuleiro para uma nova partida mantendo o mesmo modo."""
        self.tabuleiro = [VAZIO] * 9
        self.jogador_atual = HUMANO # x sempre começa após resetar
        for btn in self.botoes:
            btn.config(text=VAZIO)

if __name__ == "__main__":
    # inicializa a janela principal
    janela_principal = tk.Tk()
    # impede que quebre o layout
    janela_principal.resizable(False, False) 
    app = JogoDaVelhaGUI(janela_principal)
    janela_principal.mainloop()